# Copier ce fichier en .env et remplir les valeurs

DJANGO_SECRET_KEY=changeme-generate-a-real-key
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1

# Base de données PostgreSQL
DB_NAME=teamfit
DB_USER=teamfit
DB_PASSWORD=teamfit
DB_HOST=db
DB_PORT=5432

# Email (Gmail SMTP en V1)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=votre@gmail.com
EMAIL_HOST_PASSWORD=votre-app-password-google
DEFAULT_FROM_EMAIL=TeamFit <noreply@teamfit.app>
