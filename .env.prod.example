# ══════════════════════════════════════════════════════════════════════════════
# FitRadarHR — configuration PRODUCTION (fitradarhr.fr)
# Sur le serveur : cp .env.prod.example .env  puis remplir les valeurs <...>
# Le .env n'est JAMAIS commité (déjà dans .gitignore).
# ══════════════════════════════════════════════════════════════════════════════

# Générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=<générer-une-clé>
DEBUG=False
ALLOWED_HOSTS=fitradarhr.fr www.fitradarhr.fr
SITE_BASE_URL=https://fitradarhr.fr

# Base de données PostgreSQL (docker/docker-compose.prod.yml)
DB_NAME=fitradarhr
DB_USER=fitradarhr
# Générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(24))"
DB_PASSWORD=<générer-un-mot-de-passe>
DB_HOST=db
DB_PORT=5432

# Mode démo public — bouton "Essayer la démo" + reset quotidien (service demo-reset,
# lancé avec --profile demo). Aucun email réel envoyé par l'org de démo.
DEMO_MODE=True

# ─── Email SMTP (obligatoire en prod : liens questionnaire, relances J+3,
#     confirmations d'inscription) ─────────────────────────────────────────────
# Recommandé : Brevo (https://www.brevo.com — gratuit ≤ 300 emails/jour).
# Après inscription : Paramètres → SMTP & API → clé SMTP.
#   EMAIL_HOST=smtp-relay.brevo.com   EMAIL_PORT=587
#   EMAIL_HOST_USER=<login affiché par Brevo>   EMAIL_HOST_PASSWORD=<clé SMTP>
# Alternative Scaleway TEM : EMAIL_HOST=smtp.tem.scaleway.com (domaine à valider
# dans la console Scaleway au préalable).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=<login-smtp>
EMAIL_HOST_PASSWORD=<clé-smtp>
DEFAULT_FROM_EMAIL=FitRadarHR <noreply@fitradarhr.fr>

# ─── Stripe (abonnement 39 €/mois — laisser vide tant que non configuré :
#     l'écran /settings/billing/ affichera "configuration requise") ────────────
# Créer le produit + Price 39 €/mois dans le dashboard Stripe, puis :
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
